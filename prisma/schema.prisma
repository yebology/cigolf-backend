generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model weekly_detail {
  id                     Int                      @id @default(autoincrement())
  title_task             String
  location_id            Int
  division_id            Int
  priority               priority                 @default(P3)
  start_date             DateTime?                @default(now()) @db.Date
  hole                   String?                  @db.VarChar(255)
  detail                 String?
  is_done                Boolean?
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  bridge_weekrep_weekdet bridge_weekrep_weekdet[]
  daily_detail           daily_detail[]
  division               division                 @relation(fields: [division_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mingdet_division")
  location               location                 @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mingdet_location")
}

model region {
  id           Int            @id @default(autoincrement())
  region       String         @db.VarChar(255)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  daily_report daily_report[]
  foreman      foreman[]
}

model role {
  id         Int       @id @default(autoincrement())
  role       String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      User[]
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  password_hash String    @map("password_hash")
  name          String    @db.VarChar(255)
  role_id       Int
  phone_number  String    @db.VarChar(255)
  email         String    @db.VarChar(100)
  is_active     Boolean   @default(true)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  foreman       foreman[]
  role          role      @relation(fields: [role_id], references: [id], onDelete: NoAction, map: "fk_users_role")

  @@map("users")
}

model bridge_dailyrep_dailydet {
  id           Int           @id @default(autoincrement())
  dailyrep_id  Int?
  dailydet_id  Int?
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  daily_detail daily_detail? @relation(fields: [dailydet_id], references: [id], onDelete: Cascade, map: "fk_bridgehar_hardet")
  daily_report daily_report? @relation(fields: [dailyrep_id], references: [id], onDelete: Cascade, map: "fk_bridgehar_laphar")
}

model bridge_weekrep_weekdet {
  id            Int            @id @default(autoincrement())
  weekrep_id    Int?
  weekdet_id    Int?
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  weekly_report weekly_report? @relation(fields: [weekrep_id], references: [id], onDelete: Cascade, map: "fk_bridgeming_lapming")
  weekly_detail weekly_detail? @relation(fields: [weekdet_id], references: [id], onDelete: Cascade, map: "fk_bridgeming_mingdet")
}

model daily_detail {
  id                       Int                        @id @default(autoincrement())
  weekdet_id               Int?
  title_task               String
  location_id              Int
  division_id              Int
  priority                 priority                   @default(P3)
  hole                     String?                    @db.VarChar(255)
  worker_need              Int?
  worker_avail             Int?
  worker_name              String?
  detail                   String?
  url_photo                String?
  is_done                  Boolean                    @default(false)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  bridge_dailyrep_dailydet bridge_dailyrep_dailydet[]
  division                 division                   @relation(fields: [division_id], references: [id], onDelete: NoAction, map: "fk_hardet_division")
  location                 location                   @relation(fields: [location_id], references: [id], onDelete: NoAction, map: "fk_hardet_location")
  weekly_detail            weekly_detail?             @relation(fields: [weekdet_id], references: [id], onDelete: NoAction, map: "fk_hardet_mingdet")
}

model daily_report {
  id                       Int                        @id @default(autoincrement())
  foreman_id               Int
  date                     DateTime                   @default(now()) @db.Date
  region_id                Int
  is_approved              Boolean                    @default(false)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  bridge_dailyrep_dailydet bridge_dailyrep_dailydet[]
  foreman                  foreman                    @relation(fields: [foreman_id], references: [id], onDelete: NoAction, map: "fk_laphar_foreman")
  region                   region                     @relation(fields: [region_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_laphar_region")
}

model division {
  id            Int             @id @default(autoincrement())
  division      String          @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  daily_detail  daily_detail[]
  weekly_detail weekly_detail[]
}

model location {
  id            Int             @id @default(autoincrement())
  location      String          @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  daily_detail  daily_detail[]
  weekly_detail weekly_detail[]
}

model weekly_report {
  id                     Int                      @id @default(autoincrement())
  start_date             DateTime                 @db.Date
  end_date               DateTime                 @db.Date
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  bridge_weekrep_weekdet bridge_weekrep_weekdet[]
}

model foreman {
  id           Int            @id @default(autoincrement())
  user_id      Int
  region_id    Int
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  daily_report daily_report[]
  region       region         @relation(fields: [region_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_foreman_region")
  users        User           @relation(fields: [user_id], references: [id], onDelete: NoAction, map: "fk_foreman_users")
}

enum priority {
  P1
  P2
  P3
  P4
  P5
}
