generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model mandor {
  id           Int            @id @default(autoincrement())
  id_user      Int
  id_region    Int
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  daily_report daily_report[]
  region       region         @relation(fields: [id_region], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mandor_region")
  users        User           @relation(fields: [id_user], references: [id], onDelete: NoAction, map: "fk_mandor_users")
}

model weekly_detail {
  id                     Int                      @id @default(autoincrement())
  title_task             String
  id_location            Int
  id_division            Int
  priority               priority                 @default(P3)
  start_date             DateTime?                @default(now()) @db.Date
  hole                   String?                  @db.VarChar(255)
  detail                 String?
  is_done                Boolean?                 @default(false)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  bridge_weekrep_weekdet bridge_weekrep_weekdet[]
  daily_detail           daily_detail[]
  division               division                 @relation(fields: [id_division], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mingdet_division")
  location               location                 @relation(fields: [id_location], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mingdet_location")
}

model region {
  id           Int            @id @default(autoincrement())
  region       String         @db.VarChar(255)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  daily_report daily_report[]
  mandor       mandor[]
}

model role {
  id         Int       @id @default(autoincrement())
  role       String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      User[]
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  password_hash String    @map("password_hash")
  name          String    @db.VarChar(255)
  id_role       Int
  phone_number  String    @db.VarChar(255)
  email         String    @db.VarChar(100)
  is_active     Boolean   @default(true)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  mandor        mandor[]
  role          role      @relation(fields: [id_role], references: [id], onDelete: NoAction, map: "fk_users_role")

  @@map("users")
}

model bridge_dailyrep_dailydet {
  id           Int           @id @default(autoincrement())
  id_dailyrep  Int?
  id_dailydet  Int?
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  daily_detail daily_detail? @relation(fields: [id_dailydet], references: [id], onDelete: Cascade, map: "fk_bridgehar_hardet")
  daily_report daily_report? @relation(fields: [id_dailyrep], references: [id], onDelete: Cascade, map: "fk_bridgehar_laphar")
}

model bridge_weekrep_weekdet {
  id            Int            @id @default(autoincrement())
  id_weekrep    Int?
  id_weekdet    Int?
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  weekly_report weekly_report? @relation(fields: [id_weekrep], references: [id], onDelete: Cascade, map: "fk_bridgeming_lapming")
  weekly_detail weekly_detail? @relation(fields: [id_weekdet], references: [id], onDelete: Cascade, map: "fk_bridgeming_mingdet")
}

model daily_detail {
  id                       Int                        @id @default(autoincrement())
  id_weekdet               Int?
  title_task               String
  id_location              Int
  id_division              Int
  priority                 priority                   @default(P3)
  hole                     String?                    @db.VarChar(255)
  worker_need              Int?
  worker_avail             Int?
  worker_name              String?
  detail                   String?
  url_photo                String?
  is_done                  Boolean                    @default(false)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  bridge_dailyrep_dailydet bridge_dailyrep_dailydet[]
  division                 division                   @relation(fields: [id_division], references: [id], onDelete: NoAction, map: "fk_hardet_division")
  location                 location                   @relation(fields: [id_location], references: [id], onDelete: NoAction, map: "fk_hardet_location")
  weekly_detail            weekly_detail?             @relation(fields: [id_weekdet], references: [id], onDelete: NoAction, map: "fk_hardet_mingdet")
}

model daily_report {
  id                       Int                        @id @default(autoincrement())
  id_mandor                Int
  date                     DateTime                   @default(now()) @db.Date
  id_region                Int
  is_approved              Boolean                    @default(false)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  bridge_dailyrep_dailydet bridge_dailyrep_dailydet[]
  mandor                   mandor                     @relation(fields: [id_mandor], references: [id], onDelete: NoAction, map: "fk_laphar_mandor")
  region                   region                     @relation(fields: [id_region], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_laphar_region")
}

model division {
  id            Int             @id @default(autoincrement())
  division      String          @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  daily_detail  daily_detail[]
  weekly_detail weekly_detail[]
}

model location {
  id            Int             @id @default(autoincrement())
  location      String          @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  daily_detail  daily_detail[]
  weekly_detail weekly_detail[]
}

model weekly_report {
  id                     Int                      @id @default(autoincrement())
  start_date             DateTime                 @db.Date
  end_date              DateTime                 @db.Date
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  bridge_weekrep_weekdet bridge_weekrep_weekdet[]
}

enum priority {
  P1
  P2
  P3
  P4
  P5
}
